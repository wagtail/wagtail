msgstr "slug"

msgid ""
"The name of the page as it will appear in URLs e.g http://domain.com/blog/"
"[my-slug]/"
msgstr ""
"Naran pajina iha URL sira laran ezemplu http://domain.com/blog/[my-slug]/"

