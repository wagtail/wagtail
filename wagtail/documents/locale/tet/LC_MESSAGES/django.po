msgstr "dokumentu sira"

#, python-format
msgid "Add tags to 1 document"
msgid_plural "Add tags to %(counter)s documents"
msgstr[0] "Aumenta tag sira ba dokumentu %(counter)s"

msgid "Add tags to documents"
msgstr "Aumenta tag sira ba dokumentu"

msgid "Are you sure you want to tag the following document?"
msgid_plural "Are you sure you want to tag the following documents?"
msgstr[0] "Ita-boot serteza hakarak tag dokumentu sira tuir mai?"

msgid "You don't have permission to add tags to this document"
msgid_plural "You don't have permission to add tags to these documents"
msgstr[0] ""
"Ita-boot laiha permisaun atu aumenta tag sira ba dokumentu sira ne'e"

msgid "Yes, add"
msgstr "Sim, aumenta"

msgid "No, don't add"
msgstr "Lae, labele aumenta"

#, python-format
msgid "Add 1 document to new collection"
msgid_plural "Add %(counter)s documents to new collection"
msgstr[0] "Aumenta dokumentu %(counter)s ba kolesaun foun"

msgid "Add documents to collection"
msgstr "Aumenta dokumentu ba kolesaun"

msgid ""
"Are you sure you want to add the following document to the selected "
"collection?"
msgid_plural ""
"Are you sure you want to add the following documents to the selected "
"collection?"
msgstr[0] ""
"Ita-boot serteza hakarak aumenta dokumentu sira tuir mai ba kolesaun ne'ebé "
"hili ona?"

msgid "You don't have permission to add this document to a collection"
msgid_plural "You don't have permission to add these documents to a collection"
msgstr[0] ""
"Ita-boot laiha permisaun atu aumenta dokumentu sira ne'e ba kolesaun"

#, python-format
msgid "Delete 1 document"
msgid_plural "Delete %(counter)s documents"
msgstr[0] "Hamoos dokumentu %(counter)s"

msgid "Delete documents"
msgstr "Hamoos dokumentu sira"

msgid "Are you sure you want to delete this document?"
msgid_plural "Are you sure you want to delete these documents?"
msgstr[0] "Ita-boot serteza hakarak hamoos dokumentu sira ne'e?"

msgid "You don't have permission to delete this document"
msgid_plural "You don't have permission to delete these documents"
msgstr[0] "Ita-boot laiha permisaun atu hamoos dokumentu sira ne'e"

msgid "Yes, delete"
msgstr "Sim, hamoos"

msgid "No, don't delete"
msgstr "Lae, Labele hamoos"

msgid "Latest documents"
msgstr "Dokumentu foun sira"

#, python-format
msgid "Sorry, no documents match \"<em>%(search_query)s</em>\""
msgstr ""
"Deskulpa, la iha dokumentu sira ne'ebé koresponde \"<em>%(search_query)s</"
"em>\""

msgid ""
"Why not <a class=\"upload-one-now\" href=\"#tab-upload\" data-action=\"w-"
"tabs#select:prevent\" data-w-tabs-target=\"trigger\" data-w-tabs-focus-"
"param=\"true\">upload one now</a>?"
msgstr ""
"Tamba saida <a class=\"upload-one-now\" href=\"#tab-upload\" data-action=\"w-"
"tabs#select:prevent\" data-w-tabs-target=\"trigger\" data-w-tabs-focus-"
"param=\"true\"> la upload ida agora </a>?"

