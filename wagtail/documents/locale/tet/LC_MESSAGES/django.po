msgid "Wagtail documents"
msgstr "Wagtail dokumentu sira"

#, python-format
msgid "Maximum filesize: %(max_upload_size)s."
msgstr "File nia medida másimu: %(max_upload_size)s."

#, python-format
msgid ""
"This file is too big (%(file_size)s). Maximum filesize %(max_filesize)s."
msgstr ""
"Dokumentus ne'e bo'ot demais (%(file_size)s). Maximu Dokumentus nia medida "
"%(max_filesize)s. "

