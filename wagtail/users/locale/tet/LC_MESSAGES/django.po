msgid "Wagtail users"
msgstr "Wagtail Uzuáriu sira"

msgid "Required. Letters, digits and @/./+/-/_ only."
msgstr "Presija. Letra, díjitu no @/./+/-/_ de'it."

msgid "This value may contain only letters, numbers and @/./+/-/_ characters."
msgstr "Valor nee so bele prenxe deit ho letra, numeru no karakter @/./+/-/_"

msgid "A user with that username already exists."
msgstr "Uzuáriu ho naran uzuáriu ne'eba  eziste ona."

msgid "The two password fields didn't match."
msgstr "seña husi coluna rua nee la coresponde"

msgid "Email"
msgstr "Email"

msgid "First Name"
msgstr "Naran Dahuluk"

msgid "Last Name"
msgstr "Naran Ikus"

msgid "Password"
msgstr "Seña"

msgid "Leave blank if not changing."
msgstr "Husik mamuk karik la troka."

msgid "Password confirmation"
msgstr "Konfirama seña"

msgid "Enter the same password as above, for verification."
msgstr "Hatama seña hanesan iha leten, hodi halo verifikasaun."

msgid "Administrator"
msgstr "Administrador"

msgid "Administrators have full access to manage any object or setting."
msgstr ""
"Administrador iha dever tomak atu asesu hodi jere objetu saida deit ka "
"konfigura."

msgid "A group with that name already exists."
msgstr "Grupu ho naran nebaa existe tia ona."

msgid "You cannot have multiple permission records for the same page."
msgstr "Ita la iha autorizasaun oin-oin rekorda ba pajina hanesan."

msgid "submitted notifications"
msgstr "notifikasaun submete ona"

msgid "Receive notification when a page is submitted for moderation"
msgstr "Simu notifikasaun bainhira pajina submete ba moderasaun"

msgid "approved notifications"
msgstr "notifikasaun aprova ona"

msgid "Receive notification when your page edit is approved"
msgstr "Simu notifikasaun bainhira ita nia pajina troka aprova ona"

msgid "rejected notifications"
msgstr "notifikasaun rejeita ona"

msgid "Receive notification when your page edit is rejected"
msgstr "Simu notifikasaun bainhira ita hadia ita nia pajina lasimu"

msgid "updated comments notifications"
msgstr "atualiza ona komentáriu sira notifikasaun sira"

msgid ""
"Receive notification when comments have been created, resolved, or deleted "
"on a page that you have subscribed to receive comment notifications on"
msgstr ""
"Simu notifikasaun bainhira komentáriu sira kria ona, rezolve ona, ka apaga "
"ona iha pajina ne'ebé ita-boot subskreve ona atu simu notifikasaun "
"komentáriu sira iha"

msgid "preferred language"
msgstr "prefere lian"

msgid "Select language for the admin"
msgstr "Hili lian ba admin"

msgid "current time zone"
msgstr "zona tempu agora dadaun"

msgid "Select your current time zone"
msgstr "Hili ita nia zona agora dadaun"

msgid "profile picture"
msgstr "perfil imajen"

msgid "System default"
msgstr "Sistema padraun"

msgid "Light"
msgstr "Naroman"

msgid "Dark"
msgstr "Nakukun"

msgid "admin theme"
msgstr "tema administrasaun"

msgid "More contrast"
msgstr "Kontraste barak liután"

msgid "contrast"
msgstr "kontraste"

msgid "Default"
msgstr "Pandraun"

msgid "Snug"
msgstr "Snug"

#. Translators: "Density" is the term used to describe the amount of space
#. between elements in the user interface
msgid "density"
msgstr "Densidade"

msgid "Keyboard shortcuts"
msgstr "Dalan badak sira ba keyboard"

msgid "Enable custom keyboard shortcuts specific to Wagtail."
msgstr "Habilita dala badak sira keyboard nian ne'ebé espesífiku ba Wagtail."

msgid "user profile"
msgstr "perfil uzuáriu"

msgid "user profiles"
msgstr "perfil uzuáriu sira"

#, python-format
msgid "Assign role to 1 user"
msgid_plural "Assign role to %(counter)s users"
msgstr[0] "Atribui papél ba uzuáriu %(counter)s"

msgid "Assign role"
msgstr "Atiribui papél"

msgid "Are you sure you want to assign this role to these users?"
msgstr "Ita-boot serteza hakarak atu atribui papél ba uzuáriu sira ne'e?"

msgid "You don't have permission to edit this user"
msgid_plural "You don't have permission to edit these users"
msgstr[0] "Ita laiha permisaun atu hadia uzuáriu sira ne'e"

msgid "Yes, assign"
msgstr "Loos, atribui"

msgid "No, don't assign"
msgstr "Lae, labele atriubui"

#, python-format
msgid "Delete 1 user"
msgid_plural "Delete %(counter)s users"
msgstr[0] "Hamoos uzuáriu %(counter)s"

msgid "Delete"
msgstr "Hamoos"

msgid "Are you sure you want to delete these users?"
msgstr "Ita serteza hakarak atu hamoos uzuáriu sira ne'e?"

msgid "You don't have permission to delete this user"
msgid_plural "You don't have permission to delete these users"
msgstr[0] "Ita laiha permisaun atu hamoos uzuáriu sira ne'e"

msgid "Yes, delete"
msgstr "Sim, hamoos"

msgid "No, don't delete"
msgstr "Lae, Labele hamoos"

#, python-format
msgid "Change active state for 1 user"
msgid_plural "Change active state for %(counter)s users"
msgstr[0] "Troka estadu ativu ba uzuáriu %(counter)s"

msgid "Set active state"
msgstr "Konjunta estadu ativu"

msgid "Are you sure you want to change the active state for these users?"
msgstr "Ita serteza hakarak atu troka estadu ativu hosi uzuáriu sira ne'e?"

msgid "You cannot change your own active status"
msgstr "Ita-boot labele troka ita-boot nia estadu ativu"

msgid "Yes, change state"
msgstr "Loos, troka estadu"

msgid "No, don't change state"
msgstr "Lae, labele troka estadu"

#, python-format
msgid ""
"The group '%(group_name)s' has <strong>%(group_user_count)s</strong> member."
msgid_plural ""
"The group '%(group_name)s' has <strong>%(group_user_count)s</strong> members."
msgstr[0] ""
"Grupu %(group_name)siha membru <strong>%(group_user_count)s</strong>"

msgid ""
"Deleting this group will revoke this group's permissions from all member "
"users."
msgstr ""
"Hamoos grupu nee sei afeita ba grupu nee nia permisaun husi membru uzuáriu "
"sira."

msgid "Are you sure you want to delete this group?"
msgstr "Ita boot prontu dunik ita boot hakarak hamoos grupu nee?"

msgid "Object permissions"
msgstr "Permisaun sira ba Objetu"

msgid "Name"
msgstr "Naran"

msgid "Add"
msgstr "Hatama"

msgid "Change"
msgstr "Troka"

msgid "Custom permissions"
msgstr "Permisaun personalizadu sira"

msgid "Toggle all"
msgstr "Altera hotu"

msgid "Toggle all add permissions"
msgstr "Altera permisaun hotu ne'ebé aumenta"

msgid "Toggle all change permissions"
msgstr "Altera permisaun hotu ne'ebé troka"

msgid "Toggle all delete permissions"
msgstr "Altera permisaun hotu ne'ebé hamoos"

msgid "Toggle all custom permissions"
msgstr "Altera personalizasaun permisaun hotu"

msgid "Other permissions"
msgstr "Permisaun sira seluk"

msgid "Page permissions"
msgstr "Permisaun sira ba pajina"

msgid "Page"
msgstr "Pajina"

msgid "Add a page permission"
msgstr "Hatama permisaun ba pajina"

#, python-format
msgid "Sorry, no groups match \"%(query)s\""
msgstr "Deskulpa, laiha grupu sira apar \"1%(query)s\""

#, python-format
msgid ""
"There are no groups configured. Why not <a "
"href=\"%(wagtailusers_create_group_url)s\">add some</a>?"
msgstr ""
"Laiha grupu sira ne'ebé konfigura ona. Tamba sa labele<a "
"href=\"%(wagtailusers_create_group_url)s\">aumenta balu</a>?"

msgid "Account"
msgstr "Konta"

msgid "Roles"
msgstr "Knar"

msgid "Select all users in listing"
msgstr "Hili uzuáriu hotu iha lista"

msgid "Sorry, no users match your query"
msgstr "Deskulpa, uzuáriu sira ne'ebé ita-boot husu la koresponde"

#, python-format
msgid ""
"There are no users configured. Why not <a "
"href=\"%(wagtailusers_add_url)s\">add some</a>?"
msgstr ""
"Laiha uzuáriu sira nebee mak configura. Tamba sa la <a "
"href=\"%(wagtailusers_add_url)s\">hatama balu</a>?"

msgid "Can view"
msgstr "Bele haree"

#, python-format
msgid "user %(id)s (deleted)"
msgstr "%(id)s uzuáriu (hamoos)"

msgid "Assign role to selected users"
msgstr "Atribui papél ba uzuáriu sira ne'ebé hili ona"

#, python-format
msgid "%(num_parent_objects)d user has been assigned as %(role)s"
msgid_plural "%(num_parent_objects)d users have been assigned as %(role)s"
msgstr[0] "Uzuáriu %(num_parent_objects)d atribui ona hanesan %(role)s"

msgid "Delete selected users"
msgstr "Hamoos uzuáriu sira ne'ebé hili ona"

#, python-format
msgid "%(num_parent_objects)d user has been deleted"
msgid_plural "%(num_parent_objects)d users have been deleted"
msgstr[0] "Uzuáriu %(num_parent_objects)d hamoos ona"

msgid "Active"
msgstr "Ativu"

msgid "Inactive"
msgstr "La ativu"

msgid "Mark as active"
msgstr "Marka hanesan ativu"

msgid "Change the active state for selected users"
msgstr "Troka estadu ativu ba uzuáriu sira ne'ebé hili ona"

#, python-format
msgid "%(num_parent_objects)d user has been marked as active"
msgid_plural "%(num_parent_objects)d users have been marked as active"
msgstr[0] "Uzuáriu %(num_parent_objects)d marka ona hanesan ativu"

#, python-format
msgid "%(num_parent_objects)d user has been marked as inactive"
msgid_plural "%(num_parent_objects)d users have been marked as inactive"
msgstr[0] "Uzuáriu %(num_parent_objects)d marka ona hanesan inativu"

