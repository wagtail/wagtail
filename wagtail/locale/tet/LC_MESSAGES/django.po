msgid "Locked"
msgstr "Xavi tiha ona"

#, python-format
msgid "No one can make changes while the %(model_name)s is locked"
msgstr "Laiha ema ida mak bele halo mudansa wainhira %(model_name)s xave ona"

#, python-brace-format
msgid "<b>'{title}' was locked</b> by <b>you</b> on <b>{datetime}</b>."
msgstr ""
"<b>'{title}' xave ona</b> husi <b> ita-boot </b> iha <b>{datetime}</b>."

#, python-brace-format
msgid "<b>'{title}' is locked</b> by <b>you</b>."
msgstr "<b>'{title}' xave ona</b> husi <b>ita-boot</b>."

#, python-brace-format
msgid "<b>'{title}' was locked</b> by <b>{user}</b> on <b>{datetime}</b>."
msgstr "'<b>{title}' xave ona</b> husi <b>{user}</b> iha <b>{datetime}</b>."

#, python-brace-format
msgid "<b>'{title}' is locked</b>."
msgstr "<b>'{title}' xave ona</b>."

msgid "Locked by you"
msgstr "Xave ona husi ita-boot"

msgid "Locked by another user"
msgstr "Xave ona hosi uzuáriu seluk"

#, python-format
msgid "Only you can make changes while the %(model_name)s is locked"
msgstr "Ita-boot deit mak bele halo mudansa wainhira %(model_name)s xave ona"

#, python-format
msgid "Only %(user)s can make changes while the %(model_name)s is locked"
msgstr "%(user)s deit mak bele halo mudansa wainhira %(model_name)s xave ona"

#, python-format
msgid "This %(model_name)s is currently awaiting moderation."
msgstr "%(model_name)s ida-ne'e agora dadaun hein hela moderasaun."

#, python-brace-format
msgid ""
"This {model_name} is awaiting <b>'{task_name}'</b> in the "
"<b>'{workflow_name}'</b> workflow."
msgstr ""
"{model_name} ida-ne'e hein hela <b>'{task_name}'</b> iha "
"<b>'{workflow_name}'</b> fluxu servisu."

#, python-format
msgid "Only reviewers for this task can edit the %(model_name)s."
msgstr "Só revizadór sira ba papel ida-ne'e maka bele hadia %(model_name)s."

msgid "Unlocked"
msgstr "Loke tiha ona"

msgid "Locked by workflow"
msgstr "Xave ona husi fluxu servisu"

#, python-format
msgid ""
"Reviewers can edit this %(model_name)s – lock it to prevent other reviewers "
"from editing"
msgstr ""
"Revisor sira bele hadia %(model_name)s ida-ne'e – xave tia nia atu prevene "
"revizór sira seluk ne'ebé atu edita"

#, python-format
msgid "Only reviewers can edit and approve the %(model_name)s"
msgstr "Só revizadór sira maka bele hadia no aprova %(model_name)s"

#, python-brace-format
msgid ""
"{model_name} '{title}' is locked and has been scheduled to go live at "
"{datetime}"
msgstr ""
"{model_name} '{title}' xave ona no no marka ona oráriu atu publika diretu "
"iha {datetime}"

msgid "Locked by schedule"
msgstr "Trava tuir oráriu"

msgid "Currently locked and will go live on the scheduled date"
msgstr "Agora dadaun xave no sei publika diretu iha data ne'ebé marka ona"

